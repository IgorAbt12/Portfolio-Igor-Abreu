programa {
  funcao inicio() {

    inteiro alavanca

    escreva("Digite a posicao da alavanca: ")
    leia(alavanca)

    escolha (alavanca) {

      caso 1:
        escreva("Dinossauros")
        pare

      caso 2:
        escreva("Idade Media")
        pare

      caso 3:
        escreva("Futuro Cyberpunk")
        pare

      caso contrario:
        escreva("Vacuo Temporal")
    }

  }
}