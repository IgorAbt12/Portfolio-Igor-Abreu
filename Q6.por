programa {
  funcao inicio() {
    inteiro nota, renda 
    escreva("digite sua nota: ")
    leia (nota)

    escreva("digite sua renda em reais: ")
    leia (renda)
     se (nota>8) {
      escreva("ganhou bolsa")
     }
     se (renda<2000) {
      escreva("ganhou bolsa")
     }
     senao {escreva("nao ganhou bolsa")
     }
    }
}
